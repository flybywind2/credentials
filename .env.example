DATABASE_URL=sqlite:///./dev.db
# Private cloud example:
# DATABASE_URL=mysql+pymysql://credential_user:change-me@mysql.internal:3306/credential
# SSO_MODE supports mock, ldap, or saml.
SSO_MODE=mock
SSO_PROVIDER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SMTP_MODE=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
