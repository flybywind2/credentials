DATABASE_URL=sqlite:///./dev.db
APP_BASE_URL=http://127.0.0.1:8000
# Private cloud example:
# DATABASE_URL=mysql+pymysql://credential_user:change-me@mysql.internal:3306/credential
# SSO_MODE supports mock or broker.
SSO_MODE=mock
SSO_TOKEN_SECRET=
SSO_TOKEN_EXPIRE_MINUTES=480
SSO_ADMIN_EMPLOYEE_IDS=admin001
SSO_BROKER_EMPLOYEE_HEADER=X-Broker-Employee-Id
SSO_BROKER_NAME_HEADER=
SSO_BROKER_EMAIL_HEADER=
SSO_BROKER_DEPT_HEADER=deptname
BROKER_URL=https://sso.example.com/svc0
SERVICE_URL=https://example1.com
MAIL_MODE=disabled
MAIL_API_BASE_URL=mail.net
MAIL_API_SYSTEM_ID=
MAIL_API_TIMEOUT_SECONDS=10
