DATABASE_URL=sqlite:///./dev.db
# Private cloud example:
# DATABASE_URL=mysql+pymysql://credential_user:change-me@mysql.internal:3306/credential
# SSO_MODE supports mock, ldap, or saml.
SSO_MODE=mock
SSO_PROVIDER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_TOKEN_SECRET=
SSO_TOKEN_EXPIRE_MINUTES=480
SSO_ADMIN_EMPLOYEE_IDS=admin001
SSO_LDAP_BIND_DN_TEMPLATE={employee_id}
SSO_LDAP_SEARCH_BASE=
SSO_LDAP_SEARCH_FILTER=(sAMAccountName={employee_id})
SSO_LDAP_EMPLOYEE_ATTR=sAMAccountName
SSO_LDAP_NAME_ATTR=displayName
SSO_SAML_SP_ENTITY_ID=
SSO_SAML_ACS_URL=
SSO_SAML_IDP_ENTITY_ID=
SSO_SAML_SSO_URL=
SSO_SAML_X509_CERT=
SSO_SAML_EMPLOYEE_ATTR=employee_id
SMTP_MODE=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
